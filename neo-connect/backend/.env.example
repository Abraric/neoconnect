# Server
PORT=5000
NODE_ENV=development

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/NeoConnect

# MongoDB (Mongoose)
MONGODB_URI=mongodb://localhost:27017/NeoConnect

# Redis (Upstash — use rediss:// for TLS)
REDIS_URL=rediss://default:yourpassword@your-host.upstash.io:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# CORS
FRONTEND_URL=http://localhost:3000
